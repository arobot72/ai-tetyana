{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "skill": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "todowrite": "allow"
  },
  "agent": {
    "orchestrator": {
      "mode": "primary",
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.1,
      "color": "#2E74B5",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "task": {
          "*": "deny",
          "planner": "allow",
          "writer": "allow",
          "coder": "allow",
          "tester": "allow",
          "critic": "allow",
          "designer": "allow"
        }
      }
    },
    "planner": {
      "mode": "subagent",
      "hidden": true,
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "cat *": "allow",
          "ls *": "allow",
          "find *": "allow"
        }
      }
    },
    "writer": {
      "mode": "subagent",
      "hidden": true,
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.2,
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "deny",
          "cat *": "allow",
          "ls *": "allow"
        }
      }
    },
    "coder": {
      "mode": "subagent",
      "hidden": true,
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.1,
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "tester": {
      "mode": "subagent",
      "hidden": true,
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.1,
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "critic": {
      "mode": "subagent",
      "hidden": true,
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.1,
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "deny",
          "cat *": "allow",
          "ls *": "allow",
          "grep *": "allow",
          "git diff *": "allow",
          "git log *": "allow"
        }
      }
    },
    "designer": {
      "mode": "subagent",
      "hidden": true,
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.2,
      "permission": {
        "edit": "allow",
        "bash": {
          "mkdir *": "allow",
          "convert *": "allow",
          "curl *": "allow"
        }
      }
    }
  }
}